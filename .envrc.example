export AWS_DEFAULT_PROFILE="your-aws-profile-name"

# Proxmox provider auth
export TF_VAR_proxmox_endpoint="https://x86-node-01.levizitting.com:8006"
export TF_VAR_proxmox_api_token="sgfdevs-gha@pve!gha=your-token-secret"
export TF_VAR_proxmox_insecure="true"

# Optional: rotate generated SSH key material
export TF_VAR_vm_ssh_key_version="1"

# Optional: pin expected node names for connectivity checks
export TF_VAR_expected_node_names='["x86-node-01","x86-node-02"]'

# Ansible bootstrap defaults
export ANSIBLE_CONFIG="src/ansible/ansible.cfg"
